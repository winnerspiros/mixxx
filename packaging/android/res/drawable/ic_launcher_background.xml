<?xml version="1.0" encoding="utf-8"?>
<!--
  DJ Sugar adaptive icon background.
  Strawberry-frosting pink with a soft radial highlight at the top so the
  foreground donut reads against it on every launcher background.
  Viewport is the standard 108x108 dp adaptive-icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="36"
                android:gradientRadius="80"
                android:type="radial">
                <item android:offset="0" android:color="#FFFFB6C8"/>
                <item android:offset="1" android:color="#FFE4467F"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
